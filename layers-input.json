                    "id": "v2-irrecoverable-2024-cog",
                    "display_name": "Irrecoverable Carbon (2024)",
                    "group": "Objectives",
                    "visible": true,
                    "colormap": "reds",
                    "rescale": "0,150",
                    "legend_label": "Mg C / ha"
                }
            ]
        },
        {
